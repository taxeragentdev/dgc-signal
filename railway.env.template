# Railway → Service → Variables → Raw Editor'a yapıştırın.
# GİZLİ değerleri (TOKEN, AGENTS_JSON içindeki apiKey) kendi değerlerinizle değiştirin.
# Bu dosya örnek içindir; gerçek sırları repoya commit etmeyin.

# --- Zorunlu (Telegram) ---
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_CHAT_ID=your_chat_id

# --- Sinyal motoru (yeni skorlama; isteğe bağlı) ---
SIGNAL_THRESHOLD=36
SIGNAL_RSI_FILTER=true
SIGNAL_RSI_BLOCK_LONG=80
SIGNAL_RSI_BLOCK_SHORT=20

# --- Tarama ---
SCAN_MODE=scalp
SCAN_INTERVAL=30000
SCAN_PAIR_DELAY_MS=0
SCAN_COINS=BTC,ETH,SOL,VIRTUAL,HYPE,SUI,ASTER
STATUS_HEARTBEAT_MS=300000
SCAN_DEBUG=false

# Daha geniş TF istersen: SCAN_TIMEFRAMES=5m,15m,30m,1h veya SCAN_MODE=full

# --- Otomatik işlem (sinyal gelince Degen job) ---
AUTO_TRADE_ENABLED=true
AUTO_TRADE_NOTIFY=true
AGENTS_JSON=[{"alias":"ichimoku","apiKey":"YOUR_ACP_X_API_KEY","walletAddress":"0xYOUR_WALLET","autoTrade":true}]
DEGEN_INTEGER_PRICE_COINS=BTC,ETH

# Test trade (isteğe bağlı; gerçek emir)
# TEST_TRADE_ENABLED=false
# TEST_TRADE_SYMBOL=BTC/USDC:USDC
# TEST_TRADE_PCT=0.01

# Sabit pozisyon boyutu (riskSizing)
FIXED_MARGIN_USDC=15
FIXED_LEVERAGE=5
