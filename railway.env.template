# Railway → Service → Variables → Raw Editor'a yapıştırın.
# GİZLİ değerleri (TOKEN, AGENTS_JSON içindeki apiKey) kendi değerlerinizle değiştirin.
# Bu dosya örnek içindir; gerçek sırları repoya commit etmeyin.

# --- Zorunlu (Telegram) ---
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_CHAT_ID=your_chat_id
# İsteğe bağlı: sinyal mesajında uzun skor satırı (trend_bearish:+16 ...)
# TELEGRAM_SHOW_SCORE_DETAIL=true

# --- Strateji Seçimi (yeni: Bollinger Band eklendi) ---
# SIGNAL_STRATEGY: confluence (varsayılan) / bollinger (BB kırılma) / hybrid (ikisi)
SIGNAL_STRATEGY=bollinger

# --- Sinyal Motoru (PRO: Premium Quality + False Positive Reduction) ---
# SIGNAL_THRESHOLD: 18-95 aralığında. 
# ⭐ RECOMMENDED: 32 (safer quality), 26 (more aggressive but risky)
# Varsayılan timeframe bazlı: 5m/15m=26, 30m=30, 1h=34
SIGNAL_THRESHOLD=32

# RSI Güvenlik Filtresi - aşırı alım/satım engel (STRONGLY RECOMMENDED)
SIGNAL_RSI_FILTER=true
# LONG engellemek: RSI > 85 ise sinyal verme
SIGNAL_RSI_BLOCK_LONG=85
# SHORT engellemek: RSI < 15 ise sinyal verme
SIGNAL_RSI_BLOCK_SHORT=15

# --- Tarama Ayarları (5m/15m/30m/1h için optimize) ---
SCAN_MODE=scalp
# Bollinger strateji için önerilen: 5m,15m (band hızlı reaksiyonu yakalar)
SCAN_TIMEFRAMES=5m,15m

# Taranan coinler (virgülle ayrılmış)
SCAN_COINS=BTC,ETH,SOL,VIRTUAL,HYPE,SUI,ASTER

# Tur aralığı (ms) — her 30 sn'de 1 tam tur
SCAN_INTERVAL=30000

# Coin başına gecikme (ms) — rate limit için
SCAN_PAIR_DELAY_MS=50

# Durum özeti bildirimi Telegram'a (ms) — her 5 dk
STATUS_HEARTBEAT_MS=300000

# Debug mode — console'a detaylı skor logu
SCAN_DEBUG=false

# --- Otomatik İşlem (sinyal → Degen) ---
AUTO_TRADE_ENABLED=false
AUTO_TRADE_NOTIFY=true
AGENTS_JSON=[{"alias":"ichimoku","apiKey":"YOUR_ACP_X_API_KEY","walletAddress":"0xYOUR_WALLET","autoTrade":true}]
DEGEN_INTEGER_PRICE_COINS=BTC,ETH

# --- Sabit Pozisyon Boyutu ---
FIXED_MARGIN_USDC=15
FIXED_LEVERAGE=5

# --- Test Trade (isteğe bağlı) ---
# TEST_TRADE_ENABLED=false
# TEST_TRADE_SYMBOL=BTC/USDC:USDC
# TEST_TRADE_PCT=0.01
